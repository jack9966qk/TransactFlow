{
    "compilerOptions": {
        "target": "es2020",
        "module": "none",
        "moduleResolution": "node",
        "lib": ["es2020", "dom"],
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "noImplicitAny": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "types": ["plotly.js"],
        "typeRoots": ["./node_modules/@types"],
        "removeComments": false
    },
    "include": ["app.ts"]
}
